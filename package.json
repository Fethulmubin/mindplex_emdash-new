{
  "name": "mindplex-emdashcms",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "emdash": {
    "label": "Starter",
    "seed": "seed/seed.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "bootstrap": "emdash init",
    "typecheck": "astro check",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate:generate": "drizzle-kit generate",
    "db:migrate:push": "drizzle-kit push",
    "db:migrate:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.0",
    "@astrojs/react": "^5.0.0",
    "@node-rs/argon2": "^2.0.0",
    "astro": "^6.0.1",
    "@mindplex/plugins": "file:./plugins",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.2",
    "emdash": "^0.9.0",
    "jose": "^5.9.4",
    "pg": "^8.11.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}